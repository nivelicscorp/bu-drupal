/**
 * Converts a string to a meaningful file name.
 */
function _bu_convert_string_to_meaningful_file_name($string) {
  $string = str_replace(' ', '-', mb_strtolower($string));
  return preg_replace('/[^a-z0-9\-]/', '', $string);
}

/**
 * hook_form_alter().
 */
function bu_lawyers_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  $language =  \Drupal::languageManager()->getCurrentLanguage()->getId();
  if ($form_id == 'views_exposed_form') {
    // Exposed form of the "Lawyers Search Page" View
    if ($form['#id'] == 'views-exposed-form-lawyers-search-page') {
      $form['actions']['submit']['#value'] = t('Buscar');
      // Set placeholder property for title filter field
      $form['title']['#placeholder'] = t('Nombre del abogado');
      // Select elements does not admit placeholder property, so we have to
      // change the label of the "All" option
      $form['field_area_target_id']['#options']['All'] = t('Áreas de práctica');
      $form['field_industrias_target_id']['#options']['All'] = t('Seleccione una Industria');
      $form['field_ciudad_target_id']['#options']['All'] = t('Ciudad');
      // Validates which membership filter the user will see
      $language =  \Drupal::languageManager()->getCurrentLanguage()->getId();
      $languagesWithGender = ['es'];
      if (in_array($language, $languagesWithGender)) {
        $form['field_membership_with_gender_target_id']['#options']['All'] = t('Cargo / Rol');
        unset($form['field_membership_target_id']);
      } else {
        $form['field_membership_target_id']['#options']['All'] = t('Cargo / Rol');
        unset($form['field_membership_with_gender_target_id']);
      }
      //$form['actions']['submit']['views_exposed_form_lawyers_search_page_submit_button'] = TRUE;
    }
  }
}

