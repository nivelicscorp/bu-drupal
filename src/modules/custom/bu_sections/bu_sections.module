/**
 * Implements hook_preprocess_HOOK() for block templates of
 * '#entity_type' == block_content.
 */
function bu_sections_preprocess_block(&$variables) {
  $entity_type = !empty($variables['content']['#entity_type']) ? $variables['content']['#entity_type'] : NULL;
  if ($entity_type == 'block_content') {
    $block_content_entity = $variables['content']['#block_content'];
    // Add the classes entered in the field_block_additional_classes to the
    // block attributes
    if (!empty($block_content_entity->field_block_additional_classes) && $classes = $block_content_entity->field_block_additional_classes->getString()) {
      $classes_array = explode(' ', $classes);
      $classes_array = array_filter($classes_array);

      if (!empty($variables['attributes']['class']) && is_array($variables['attributes']['class'])) {
        $variables['attributes']['class'] = array_merge($variables['attributes']['class'], $classes_array);
      }
      else {
        $variables['attributes']['class'] = $classes_array;
      }
    }
  }
}

/**
 * Implements hook_pathauto_alias_alter().
 */
function bu_sections_pathauto_alias_alter(&$alias, array &$context) {
  // Taxonomy terms
  if ($context['module'] == 'taxonomy' && !empty($context['data']['term'])) {
    $term = $context['data']['term'];
    $vid = $term->bundle();

    // Section children terms
    if ($vid == 'section' && $parents = _taxonomy_term_is_children($term->id())) {
      $path_alias_manager = \Drupal::service('path.alias_manager');
      $parent = reset($parents);
      $language = !empty($context['language']) ? $context['language'] : NULL;
      $parent_term_source_path = '/taxonomy/term/' . strval($parent->id());
      $parent_alias = $path_alias_manager->getAliasByPath($parent_term_source_path, $language);
      if ($parent_alias != $parent_term_source_path) {
        $parent_alias = trim($parent_alias, '/');
        $alias = trim($alias, '/');
        $alias = '/' . $parent_alias . '/' . $alias;
      }
    }

    // Áreas de práctica & Industrias
    if (in_array($vid, ['areas', 'indrustrias'])) {
      $router_provider = \Drupal::service('router.route_provider');
      $route_name_what_we_doing_page = 'view.what_we_doing.page_1';
      $route_object_what_we_doing_page = $router_provider->getRouteByName($route_name_what_we_doing_page);
      $alias = trim($alias, '/');
      $alias = $route_object_what_we_doing_page->getPath() . '/' . $alias;
    }
  }

  // Nodes
  if ($context['module'] == 'node' && !empty($context['data']['node'])) {
    $node = $context['data']['node'];
    $node_type = $node->getType();
    $router_provider = \Drupal::service('router.route_provider');
    // Newsletter nodes
    if ($node_type == 'bulletin') {
      $route_name_newsletter_page = 'view.newsletter.page_1';
      $route_object_newsletter_page = $router_provider->getRouteByName($route_name_newsletter_page);
      $alias = trim($alias, '/');
      $alias = $route_object_newsletter_page->getPath() . '/' . $alias;
    }
    // Lawyers nodes
    if ($node_type == 'lawyer') {
      $route_name_lawyer_search_page = 'view.lawyers.search_page';
      $route_object_lawyer_search_page = $router_provider->getRouteByName($route_name_lawyer_search_page);
      $alias = trim($alias, '/');
      $alias = $route_object_lawyer_search_page->getPath() . '/' . $alias;
    }
    // Noticias nodes (news)
    if ($node_type == 'noticia') {
      $route_name_noticias_page = 'view.interna_insights.page_1';
      $route_object_noticias_page = $router_provider->getRouteByName($route_name_noticias_page);
      $alias = trim($alias, '/');
      $alias = $route_object_noticias_page->getPath() . '/' . $alias;
    }
  }
}

function bu_sections_theme($existing, $type, $theme, $path) {
  return array(
    'bu_register_free_event_block' => array(
      'variables' => array(
        'title' => '',
        'items' => array(),
      )
    ),
    'bu_register_pay_event_block' => array(
      'variables' => array(
        'title' => '',
        'items' => array(),
      )
    ),
  );
}

/**
 * Implements hook_views_query_alter().
 */
function bu_sections_views_query_alter(ViewExecutable $view, QueryPluginBase $query) {
  if ($view->id() == 'lawyers') {
    $filters = array_keys($view->exposed_raw_input);
    $mermeship_fields = [
      "field_membership_with_gender_target_id",
      //"field_membership_target_id"
    ];
    $mermeship_field_names = [
      'Director',
      //'Directora'
    ];
    foreach ($mermeship_fields as $mermeship_field_item) {
      if (in_array($mermeship_field_item, $filters)) {
        $mermeship_field = $mermeship_field_item;
        break;
      }
    }
    if (isset($mermeship_field) && $view->exposed_raw_input[$mermeship_field] !== 'All') {
      /**
       * @var \Drupal\taxonomy\Entity\Term $term
       */
      $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($view->exposed_raw_input[$mermeship_field]);
      if (!empty($term) && in_array($term->getName(), $mermeship_field_names)) {
        unset($query->orderby[0], $query->orderby[1]);
      }
    }
  }
}

/**
 * Helper: returns parent terms if the given term is a child, or empty array.
 */
function _taxonomy_term_is_children($tid) {
  $parents = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadParents($tid);
  return !empty($parents) ? $parents : [];
}
