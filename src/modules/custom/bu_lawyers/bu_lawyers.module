/**
 * hook_preprocess_HOOK().
 */
function bu_lawyers_module_implements_alter(&$implementations, $hook) {
  if ($hook == 'form_alter') {
    $group = $implementations['bu_lawyers'];
    unset($implementations['bu_lawyers']);
    $implementations['bu_lawyers'] = $group;
  }
}

/**
 * hook_preprocess_HOOK().
 */
function bu_lawyers_preprocess_node(&$variables) {
  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];
  $node_type = $node->getType();
  $view_mode = $variables['view_mode'];

  // Customizations when a Lawyer node is being viewed
  if ($node_type == 'lawyer') {
    // Custom label for field_admitido_en
    $variables['content']['field_admitido_en']['#title'] = t('Admitido al ejercicio del derecho en:');

    // Customizations when the Lawyer is being viewed in Teaser view mode
    if ($view_mode == 'teaser') {
      // Break down the image field information so that we can use the twig filter
      // image_style(). This allows to use different image styles for the lawyer
      // in view mode teaser, depending of the context where it is displayed
      $variables['lawyer_image_fid'] = NULL;
      $variables['lawyer_image_alt'] = '';
      $variables['lawyer_image_title'] = '';
      $variables['lawyer_image_style'] = 'img_300x300';

      if ($node->field_image && $lawyer_image = $node->field_image->first()) {
        $variables['lawyer_image_fid'] = $lawyer_image->getValue()['target_id'];
        $variables['lawyer_image_alt'] = $lawyer_image->getValue()['alt'];
        $variables['lawyer_image_title'] = $lawyer_image->getValue()['title'];
      }
      // If a custom image style was set
      if (!empty($variables['elements']['#lawyer_image_style'])) {
        $variables['lawyer_image_style'] = $variables['elements']['#lawyer_image_style'];
      }
    }

    // Set the membership data by language
    $language =  \Drupal::languageManager()->getCurrentLanguage()->getId();
    $languagesWithGender = ['es'];
    if (in_array($language, $languagesWithGender)) {
      if ($node->field_membership_with_gender && !$node->field_membership_with_gender->isEmpty()) {
        $variables['content']['field_membership'] = $variables['content']['field_membership_with_gender'];
      }
    }
  }
}

/**
 * Implements hook_preprocess_HOOK().
 */
function bu_lawyers_preprocess_page(&$variables) {
  $route_match = \Drupal::routeMatch();
  $route_name = $route_match->getRouteName();
  // When viewing the Lawyers home page
  if ($route_name == 'view.lawyers.search_page') {
    // Custom classes for Lawyers home page
    $variables['attributes']['class'][] = 'profesionals';

    // Custom header for Lawyers home page
    $variables['page']['header'][] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => [
          'title-section-content'
        ],
      ],
      '#children' => [
        [
          '#type' => 'html_tag',
          '#tag' => 'h2',
          '#value' => t('Encuentre un abogado'),
        ],
        /*[
          '#type' => 'html_tag',
          '#tag' => 'p',
          '#value' => t('Tenemos un equipo especializado en varias áreas del derecho de los negocios que trabaja con los más altos estándares de excelencia profesional y humana.'),
        ],*/
      ],
    ];

    // Custom header banner informatioin
    $variables['header_banner_title'] = t('Buscar un profesional');
    $variables['header_banner_description'] = t('Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt.');
  }
}

