{% set container_classes = [
  'outstanding-items-container',
  is_floating ? 'is-floating',
  ]
%}
<div {{ attributes.addClass(container_classes) }}>
  <div class="outstanding-items-title">
    <h2 class="title title-color-{{ title_color}}">{{ title|trans }}</h2>
  </div>
  <div class="outstanding-items-wrapper">
    <div class="outstanding-items-items">
      {% for item in items %}
        <div class="outstanding-item-item">
          <p class="outstanding-item-category"><a href="#">{{ item.category }}</a></p>
          <h3 class="outstanding-item-text"><a href="#">{{ item.text }}</a></h3>
        </div>
      {% endfor %}
    </div>
    <div class="outstanding-items-bottom">
      <a class="outstanding-items-bottom-text link-red" href="{{ bottom_link_url }}">{{ bottom_link_text }}</a>
    </div>
  </div>  
</div>