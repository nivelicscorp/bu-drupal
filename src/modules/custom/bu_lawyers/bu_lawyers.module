/**
 * hook_preprocess_HOOK().
 */
function bu_lawyers_preprocess_field(&$variables) {
  $entity_type = isset($variables['element']['#entity_type']) ? $variables['element']['#entity_type'] : NULL;
  $bundle = isset($variables['element']['#bundle']) ? $variables['element']['#bundle'] : NULL;
  $view_mode = isset($variables['element']['#view_mode']) ? $variables['element']['#view_mode'] : NULL;

  // Lawyer's fields
  if ($entity_type == 'node' && $bundle == 'lawyer') {
    if ($view_mode == 'full') {
      // Fields which label has to be a h2 tag
      $fields_with_label_h2 = [
        'field_experiencia',
        'field_formacion_educativa'
      ];
      if (in_array($variables['element']['#field_name'], $fields_with_label_h2)) {
        $label = $variables['label'];
        $variables['label'] = [
          '#type' => 'html_tag',
          '#tag' => 'h2',
          '#value' => $label,
        ];
      }
    }
  }
}

