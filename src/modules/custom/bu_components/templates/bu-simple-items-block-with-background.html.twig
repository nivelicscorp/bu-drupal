{% set container_classes = [
  'simple-items-block-container',
  is_floating ? 'is-floating',
  'simple-items-block-color--' ~ background_color,
  ]
%}
<div {{ attributes.addClass(container_classes) }}>
  <div class="simple-items-block-title">
    <h2 class="title">{{ title|trans }}</h2>
  </div>
  <div class="simple-items-block-items-wrapper">
    <div class="simple-items-block-items">
      {% for item in items %}
        <div class="simple-items-block-item">
          <p class="simple-items-block-item-text">{{ item }}</p>
        </div>
      {% endfor %} 
    </div>
  </div>  
</div>