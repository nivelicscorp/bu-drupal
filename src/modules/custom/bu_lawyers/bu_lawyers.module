function bu_lawyers_views_pre_build(\Drupal\views\ViewExecutable $view) {
  if ($view->id() == 'news_internat') {
    if ($view->getTitle() == 'Noticias interna') {
      $node = null;
      foreach (\Drupal::routeMatch()->getParameters() as $param) {
        if ($param instanceof \Drupal\Core\Entity\EntityInterface) {
          $node = $param;
          $type = $node->getType();
        }
      }
      if ($type !== null) {
        $areas = $node->get('field_area')->getValue();
        if (count($areas) > 0) {
          foreach ($areas as $area) {
            $areas_filter[] = $area['target_id'];
          }
          $view->setExposedInput([
            'nid' => $node->id(),
            'field_area_target_id' => $areas_filter,
            //'field_industrias_target_id' => $industrias_filter
          ]);
        }
        $industrias = $node->get('field_industrias')->getValue();
        if (count($industrias) > 0) {
          foreach ($industrias as $industria) {
            $industrias_filter[] = $industria['target_id'];
          }
        }
      }
    }
  }
}

function bu_lawyers_views_pre_render(\Drupal\views\ViewExecutable $view) {
  if ($view->id() == 'duplicado_de_noticias_asociadas_boletines') {
    if ($view->getTitle() == 'Paginador noticias boletines') {
      if (isset($_GET['boletin'])) {
        $node = NULL;
        foreach (\Drupal::routeMatch()->getParameters() as $param) {
          if ($param instanceof \Drupal\Core\Entity\EntityInterface) {
            $node = $param;
            $nid = $node->id();
          }
        }
        $boletin = \Drupal\node\Entity\Node::load($_GET['boletin']);
        $relacionadas = $boletin->get('field_noticias_asociadas')->getValue();
        if (count($relacionadas) > 0) {
          foreach ($relacionadas as $k => $noticia) {
            if ($noticia['target_id'] == $nid) {
              $paginador[0] = $relacionadas[$k - 1]['target_id'];
              $paginador[1] = $relacionadas[$k + 1]['target_id'];
            }
          }
        }
      }
      $i = 1;
      foreach ($view->result as $r) {
        if (in_array($r->_entity->id(), $paginador)) {
          $r->index = $i;
          $result[] = $r;
          $i++;
        }
      }
      $view->result = [];
      $view->result = $result;
    } elseif ($view->getTitle() == 'page interna boletines') {
      $ids = array();
      $i = 0;
      foreach ($view->result as $item) {
        if (!in_array($item->nid, $ids)) {
          $item->index = $i;
          $ids[] = $item->nid;
          $result[] = $item;
          $i++;
        }
      }
      $view->result = [];
      $view->result = $result;
    }
  }
}

function get_pay_button($id) {
  $webform_submission = \Drupal\webform\Entity\WebformSubmission::load($id);
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $nid = $webform_submission->getElementData('evento');
  $evento = $node_storage->load($nid);
  $valor_evento = $evento->get('field_v')->getValue();
  $tipo_form = $webform_submission->get('webform_id')->getValue();
  if ($tipo_form[0]['target_id'] == "inscripcion_evento_pago_juridica") {
    $invitados = $webform_submission->getElementData('agregar_un_asistente');
    $nombre = $webform_submission->getElementData('nombre_de_la_empresa');
    $correo = $webform_submission->getElementData('correo_factura');
    $valor_pagar = $valor_evento[0]['value'] * count($invitados);
    $factura_previa = $webform_submission->getElementData('pago_con_factura');
  } else {
    $nombre = $webform_submission->getElementData('nombre') . ' ' . $webform_submission->getElementData('apellido');
    $correo = $webform_submission->getElementData('correo_electronico');
    $valor_pagar = $valor_evento[0]['value'];
  }
  if ($factura_previa == 1) {
    return '';
  }
  $moneda = "COP";
  $key = "13d93a0a460";
  $merchant_id = "99242";
  $reference = "Pago evento ($nombre) - " . time();
  $iva = $valor_pagar * 0.19;
  $valor_pagar = $valor_pagar + $iva;
  $firma = get_signature($key, $merchant_id, $reference, $valor_pagar, $moneda);
  $form = '
  <form method="POST" action="https://checkout.payulatam.com/ppp-web-gateway-payu">
      <input type="hidden" formControlName="merchantId" name="merchantId" value="' . $merchant_id . '" />
      <input type="hidden" formControlName="ApiKey" name="ApiKey" value="' . $key . '" />
      <input type="hidden" formControlName="referenceCode" name="referenceCode" value="' . $reference . '" />
      <input type="hidden" formControlName="accountId" name="accountId" value="103283" />
      <input type="hidden" formControlName="description" name="description" value="' . $reference . '" />
      <input type="hidden" formControlName="amount" name="amount" value="' . $valor_pagar . '" />
      <input type="hidden" formControlName="tax" name="tax" value="' . $iva . '" />
      <input type="hidden" formControlName="taxReturnBase" name="taxReturnBase" value="0" />
      <input type="hidden" formControlName="currency" name="currency" value="' . $moneda . '" />
      <input type="hidden" formControlName="signature" name="signature" value="' . $firma . '" />
      <input type="hidden" formControlName="test" name="test" value="0" />
      <input type="hidden" formControlName="buyerEmail" name="buyerEmail" value="' . $correo . '" />
      <input type="hidden" formControlName="payerFullName" name="payerFullName" value="' . $nombre . '" />
      <input type="hidden" formControlName="responseUrl" name="responseUrl" value="https://bu.com.co/es/resultado-transaccion" />
      <input type="submit" class="btn btn-primary" value="Pagar" />
    </form>
    ';
  return $form;
}

function get_signature($api_key, $merchant_id, $reference, $valor, $moneda) {
  return md5("$api_key~$merchant_id~$reference~$valor~$moneda");
}


/**
 * Implements hook_mail().
 */
function bu_lawyers_mail($key, &$message, $params) {
  $options = array(
    'langcode' => $message['langcode'],
  );

  switch ($key) {
    case 'transaccion':
      $message['from'] = \Drupal::config('system.site')->get('mail');
      $message['subject'] = t('Resultado de su transacción');
      $message['body'][] = $params['message'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed; delsp=yes';
      break;
  }
}

