<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\views\Views;
use Drupal\views\ViewExecutable;
use Drupal\views\Plugin\views\query\QueryPluginBase;

/**
 * Implements hook_form_alter().
 */
function bu_sections_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if ($form_id == 'taxonomy_term_section_form') {
    $form['description']['widget'][0]['#format'] = 'full_html';
  } elseif (strpos($form_id, 'webform_submission_inscripcion_evento') !== FALSE){
    if(isset($form['elements']['evento'])){
      $route_match = \Drupal::routeMatch();
      $current_path_parameters = $route_match->getParameters();
      // Filter for content type.
      if (isset($current_path_parameters->all()['node']) && $node = $current_path_parameters->all()['node']) {
        $form['elements']['evento']['#default_value'] = $node->id();
      }
    }
  } elseif (strpos($form_id, 'descarga_informe') !== FALSE) {
    $route_match = \Drupal::routeMatch();
    $current_path_parameters = $route_match->getParameters();
    $node = $current_path_parameters->all()['node'];
    if ($node && $node->hasField('field_archivo_des')) {
      $uri = $node->get('field_archivo_des')->entity->getFileUri();
      $url = \Drupal::service('file_url_generator')->generateAbsoluteString($uri);
      $form['elements']['archivo']['#default_value'] = $url;
    }

  }
  $webform_id = isset($form['#webform_id']) ? $form['#webform_id'] : null;
  $formsWithEmblue = ['boletin'];
  if (in_array($webform_id, $formsWithEmblue)) {
    $form['#validate'][] = 'submission_newsletter_send_em_blue';
  }
}

/**
 * Submit dates for emBlue.
 */
function submission_newsletter_send_em_blue(array &$form, FormStateInterface $form_state) {
    /**
     * @var \Drupal\bu_sections\Controller\EmBlueControllerInterface $emBlueController
     */
    $emBlueController = \Drupal::service('bu_sections.EmBlue');
    $emBlueController->sendNewsletterFormData($form_state->getValues());
}

/**
 * Implements hook_preprocess_HOOK().
 */
function bu_sections_preprocess_taxonomy_term__section(&$variables) {
  $section_term = $variables['term'];
  $view_mode = $variables['view_mode'];

  if ($view_mode == 'teaser') {
    if (!empty($variables['elements']['#even_odd'])) {
      $variables['attributes']['class'][] = $variables['elements']['#even_odd'];
    }
    $variables['read_more_link'] = [
      '#theme' => 'bu_expanded_rounded_button_arrow',
      '#link_url' =>  \Drupal\Core\Url::fromRoute('entity.taxonomy_term.canonical', ['taxonomy_term' => $section_term->id()]),
      '#link_text' => t('LEER MÁS'),
    ];
  }

  if ($view_mode == 'full') {
    if ($parent_terms = _taxonomy_term_is_children($section_term->id())) {
      $parent_term = reset($parent_terms);
      $section_terms_uuids = \Drupal::state()->get('bu_section_terms_uuids', []);
      if (!empty($section_terms_uuids['pasantias_verano'])) {
        // If the term is a children of "Pasantías de Verano"
        if ($section_terms_uuids['pasantias_verano'] == $parent_term->uuid()) {
          // Get the view "section_children_terms"
          $args = [$section_term->id()];
          $display_id = "highlighted_in_internship";
          $content_by_section_view = Views::getView('content_by_section');
          $content_by_section_view->setArguments($args);
          $content_by_section_view->setDisplay($display_id);
          $content_by_section_view->preExecute();
          $content_by_section_view->execute();
          $variables['content_by_section_block'] = $content_by_section_view->buildRenderable($display_id);
        }
      }
    }
  }
}

/**
 * Implements hook_preprocess_HOOK().
 */
function bu_sections_preprocess_taxonomy_term__section_home(&$variables) {
  $entity_type_manager = \Drupal::entityTypeManager();
  $section_term = $variables['term'];
  if (!$entity_type_manager->getStorage('taxonomy_term')->loadParents($section_term->id())) {
    // Get the view "section_children_terms"
    $args = [$section_term->id()];
    $display_id = "interleaved_block";
    $section_children_view = Views::getView('section_children');
    $section_children_view->setArguments($args);
    $section_children_view->setDisplay($display_id);
    $section_children_view->preExecute();
    $section_children_view->execute();
    $variables['section_children_terms'] = $section_children_view->buildRenderable($display_id);
  }
}

/**
 * Implements hook_theme_suggestions_HOOK_alter().
 */
function bu_sections_theme_suggestions_page_alter(array &$suggestions, array $variables) {
  $route_match = \Drupal::routeMatch();
  $route_name = $route_match->getRouteName();
  if ($route_name == 'entity.taxonomy_term.canonical') {
    $taxonomy_term = $route_match->getParameter('taxonomy_term');
    if ($taxonomy_term->bundle() == 'section') {
      if (_taxonomy_term_is_children($taxonomy_term->id())) {
        $suggestions[] = 'page__sidebar_two';
      }
    }
  }
}

/**
 * Implements hook_theme_suggestions_HOOK_alter().
 */
function bu_sections_theme_suggestions_taxonomy_term_alter(array &$suggestions, array $variables) {
  $entity_type_manager = \Drupal::entityTypeManager();
  $taxonomy_term = $variables['elements']['#taxonomy_term'];
  $view_mode = $variables['elements']['#view_mode'];
  $suggestions[] = 'taxonomy_term__' . $taxonomy_term->bundle() . '__' . $view_mode;

  if ($taxonomy_term->bundle() == 'section') {
    if (!$entity_type_manager->getStorage('taxonomy_term')->loadParents($taxonomy_term->id())) {
      $suggestions[] = 'taxonomy_term__section_home';
    }
  }
}

/*
 * Implements hook_preprocess_HOOK().
 */

function bu_sections_preprocess_views_view_unformatted__section_children__interleaved_block(&$variables) {
  $even = TRUE;
  foreach ($variables['rows'] as &$row) {
    if ($even) {
      $class = "even";
    }
    else {
      $class = "odd";
    }
    $row['content']['#even_odd'] = $class;
    $even = !$even;
  }
}

/*
 * Implements hook_preprocess_HOOK().
 */

function bu_sections_preprocess_views_view__content_by_section__block_content_by_section(&$variables) {
  $variables['header'] = [
    '#type' => 'html_tag',
    '#tag' => 'h3',
