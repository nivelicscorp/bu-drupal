<?php

/**
 * @file
 * Contains the required Drupal hooks, primarily for theming the output.
 */

use Drupal\Component\Utility\Xss;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function views_vcards_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.views_vcards':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The Views vCards module allows the exporting of user fields in a vCard format. This is mainly done because there was no way to export core user fields to a vCard format without user intervention.') . '</p>';
      $output .= '<h3>' . t('Configuration') . '</h3>';
      $output .= '<p>' . t('Create or edit a View showing users (or any other other entity) and create a new display of type <em>vCard</em>. In this display choose vCards for both <em>Format</em> and <em>Show</em>. The settings dialog for <em>Show</em> will allow you to select which field should be used for each vCard property.') . '</p>';
      $output .= '<p>' . t('Make sure the fields you want to use are added in the fields section, otherwise they will not show up.') . '</p>';
      $output .= '<p>' . t('Views vCards offers the <em>attach to</em>e> option under vCard settings, allowing this module to add a download link to another page. You can set up your user list as a normal view with all (exposed) filters if you require them, and the vCard export will adapt to the selected filters and provide the right vCards.') . '</p>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function views_vcards_theme($existing, $type, $theme, $path) {
  return [
    'views_vcards_view_row_vcard' => [
      'variables' => [
        'first_name' => NULL,
        'middle_name' => NULL,
        'last_name' => NULL,
        'full_name' => NULL,
        'title' => NULL,
        'email' => NULL,
        'email2' => NULL,
        'email3' => NULL,
        'photo' => NULL,
        'home_address' => NULL,
        'home_city' => NULL,
        'home_state' => NULL,
        'home_zip' => NULL,
        'home_country' => NULL,
        'home_phone' => NULL,
        'home_cellphone' => NULL,
        'home_website' => NULL,
        'work_title' => NULL,
        'work_company' => NULL,
        'work_address' => NULL,
        'work_city' => NULL,
        'work_state' => NULL,
        'work_zip' => NULL,
        'work_fax' => NULL,
        'work_website' => NULL,
      ],
    ],
    'views_vcards_vcard_icon' => [
      'variables' => [
        'url' => NULL,
        'title' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_HOOK() for views_vcards_view_row_vcard.
 *
 * Filters HTML from all row fields (except photo which is always safe).
 */
function views_vcards_preprocess_views_vcards_view_row_vcard(&$variables) {
  $item = $variables['row'];
  $xss = new Xss();
  $renderer = \Drupal::service('renderer');

  $variables['first_name']     = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->first_name), []), ENT_QUOTES | ENT_HTML5);
  $variables['middle_name']    = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->middle_name), []), ENT_QUOTES | ENT_HTML5);
  $variables['last_name']      = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->last_name), []), ENT_QUOTES | ENT_HTML5);
  $variables['full_name']      = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->full_name), []), ENT_QUOTES | ENT_HTML5);
  $variables['title']          = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->title), []), ENT_QUOTES | ENT_HTML5);
  $variables['email']          = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->email), []), ENT_QUOTES | ENT_HTML5);
  $variables['email2']         = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->email2), []), ENT_QUOTES | ENT_HTML5);
  $variables['email3']         = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->email3), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_address']   = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_address), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_city']      = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_city), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_state']     = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_state), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_zip']       = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_zip), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_country']   = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_country), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_phone']     = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_phone), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_cellphone'] = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_cellphone), []), ENT_QUOTES | ENT_HTML5);
  $variables['home_website']   = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->home_website), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_title']     = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_title), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_company']   = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_company), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_address']   = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_address), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_city']      = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_city), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_state']     = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_state), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_zip']       = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_zip), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_country']   = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_country), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_phone']     = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_phone), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_fax']       = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_fax), []), ENT_QUOTES | ENT_HTML5);
  $variables['work_website']   = htmlspecialchars_decode($xss::filter($renderer->renderInIsolation($item->work_website), []), ENT_QUOTES | ENT_HTML5);
  $variables['photo']          = $item->photo;
}
